# source: https://github.com/topoteretes/cognee/blob/main/.env.template
# LLM
LLM_API_KEY=local
LLM_PROVIDER=openai
LLM_MODEL=openai/gemma
LLM_ENDPOINT=http://llama:8080/v1
# Instructor mode - critical for llama.cpp which does not support parallelism
# - LLM_INSTRUCTOR_MODE=json_mode
LLM_INSTRUCTOR_MODE=baml
STRUCTURED_OUTPUT_FRAMEWORK=baml
BAML_LLM_PROVIDER=openai
BAML_LLM_MODEL=openai/gemma
BAML_LLM_ENDPOINT=http://llama:8080/v1
BAML_LLM_API_KEY=local
BAML_LLM_API_VERSION=""
      
# Embeddings (llama.cpp também serve embeddings)
EMBEDDING_API_KEY=local
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_ENDPOINT=http://embeddings:8081/v1
EMBEDDING_DIMENSIONS=768
EMBEDDING_MAX_TOKENS=8192

# NOVAS CONFIGURAÇÕES PARA BANCO DE DADOS
# Banco relacional (obrigatório para pgvector)
DB_PROVIDER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cognee_db
DB_USERNAME=cognee_user
DB_PASSWORD=cognee_password
      
# Banco vetorial usando pgvector
VECTOR_DB_PROVIDER=pgvector
# NÃO precisa definir VECTOR_DB_URL, pois reusa a conexão do PostgreSQL

# deactivate authentication for local use
REQUIRE_AUTHENTICATION=false
ENABLE_BACKEND_ACCESS_CONTROL=false