# change for "production" when stabe, "development" for better debugging 
NODE_ENV=development
# -------------------------------------------------------------
# https://openclawdoc.com/docs/reference/environment-variables/
# -------------------------------------------------------------
# (not in docs, found in code) openclaw filesystem isolation
# found this searching for OPENCLAW_HOME inside openclaw github repo
OPENCLAW_HOME=/workspace/.openclaw-data
# (found in docs, not in code) Path to config file => default ./config.yaml
# OPENCLAW_CONFIG=/workspace/.openclaw_data/openclaw.json
# found these searching for OPENCLAW_CONFIG inside openclaw github repo
OPENCLAW_CONFIG_DIR=/workspace/.openclaw_data
OPENCLAW_CONFIG_PATH=/workspace/.openclaw_data/openclaw.json
# (found in docs, not in code) OPENCLAW_LOG_FILE	Log file path => default	stdout
# OPENCLAW_LOG_FILE=/workspace/.openclaw_data/logs/logging.output
# found this searching for OPENCLAW_LOG inside openclaw github repo
OPENCLAW_LOG_DIR=/workspace/.openclaw_data/logs
# where OpenClaw, a self-hosted AI agent, stores its configuration, memory, session data, and workspace files
# didn't find it anywhere... (not in docs, not in code)
# OPENCLAW_WORKSPACE=/workspace/.openclaw_data
# found this searching for OPENCLAW_WORKSPACE inside openclaw github repo
OPENCLAW_WORKSPACE_DIR=/workspace/.openclaw_data
# OpenClaw Gateway Token is like a password for the "Gateway"
# passs it as an argument instead, while doing "pnpm openclaw gateway --token ..."
# OPENCLAW_GATEWAY_TOKEN=...
# define the network port on which the gateway service listens
OPENCLAW_GATEWAY_PORT=18789
# define the network port for the OpenClaw bridge service
OPENCLAW_BRIDGE_PORT=18790
# The agent only accepts connections from the machine it is running on
GATEWAY_BIND=loopback   
# Sets the container's user ID to the value of the host's UID environment variable. If UID is not set, it defaults to 1000
PUID=${UID:-1000}
# Sets the container's group ID to the value of the host's GID environment variable. If GID is not set, it defaults to 1000
PGID=${GID:-1000}
# didn't find it anywhere... already defined in openclaw.json
#LLM_TYPE=openai
# didn't find it anywhere... already defined in openclaw.json
#OPENAI_API_BASE=http://llama:8080/v1
# didn't find it anywhere... already defined in openclaw.json
#OPENAI_BASE_URL=http://llama:8080/v1
# api key, but since it is local it can be any string
OPENAI_API_KEY=llamacpp-local
# didn't find it anywhere... already defined in openclaw.json
MODEL_NAME=gemma-3-4b-it-q4_0.gguf
# Deprecated - used before to control internet connection, just run "bash maintenance-on/off.sh"
# PROXY_MODE=OPEN  # Variável de controle: RESTRICTED ou OPEN
# used for internet access in maintenance occasions
HTTP_PROXY=http://open_proxy_temp:3128
HTTPS_PROXY=http://open_proxy_temp:3128
# Rules out internal services from proxy
NO_PROXY=localhost,127.0.0.1,llama